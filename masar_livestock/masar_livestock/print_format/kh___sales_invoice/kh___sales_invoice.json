 "doctype": "Print Format",
 "font_size": 14,
 "html": "<style>\r\n.inv-wrapper { width: 100%; font-family: Arial, Helvetica, sans-serif; font-size: 13px; line-height: 1.4; color: #222; direction: rtl; }\r\n.top-header { width: 100%; border-bottom: 2px solid #777; padding-bottom: 10px; margin-bottom: 12px; }\r\n.top-header table { width: 100%; border-collapse: collapse; }\r\n.top-header td { vertical-align: middle; }\r\n.items-table { width: 100%; border-collapse: collapse; margin-top: 8px; margin-bottom: 10px; }\r\n.items-table th, .items-table td { border: 1px solid #666; padding: 6px 5px; text-align: center; font-size: 13px; }\r\n.items-table th { background: #f3f3f3; font-weight: 700; }\r\n.note-row { width: 100%; border-collapse: collapse; margin-top: 8px; margin-bottom: 18px; }\r\n.note-row td { border: 1px solid #888; padding: 6px 8px; font-size: 13px; }\r\n.signatures { width: 100%; margin-top: 18px; margin-bottom: 30px; }\r\n.signatures table { width: 100%; border-collapse: collapse; }\r\n.signatures td { width: 50%; text-align: center; vertical-align: top; font-size: 14px; padding-top: 10px; }\r\n.signatures .sig-title { font-weight: bold; margin-bottom: 10px; }\r\n\r\n@page { margin-bottom: 60px; }\r\n.page-footer {\r\n    position: fixed;\r\n    bottom: 0;\r\n    left: 0;\r\n    right: 0;\r\n    width: 100%;\r\n    border-top: 1px solid #777;\r\n    padding-top: 8px;\r\n    font-size: 13px;\r\n    background: #fff;\r\n    direction: rtl;\r\n}\r\n</style>\r\n\r\n<!-- Page Footer -->\r\n<div class=\"page-footer\">\r\n  <table style=\"width:100%; border-collapse:collapse;\">\r\n    <tr>\r\n      <td style=\"padding:3px 4px; vertical-align:middle; text-align:right; white-space:nowrap;\"><strong>\u0627\u0644\u0639\u0646\u0648\u0627\u0646 :</strong> \u0627\u0644\u0639\u0631\u0627\u0642 - \u0628\u063a\u062f\u0627\u062f - \u062d\u0633\u064a\u0646\u064a\u0629 \u0627\u0644\u0645\u0639\u0627\u0645\u0644 - \u0634\u0627\u0631\u0639 \u0645\u0639\u0645\u0644 \u0637\u0627\u0628\u0642 \u0628\u063a\u062f\u0627\u062f</td>\r\n      <td style=\"padding:3px 4px; vertical-align:middle; text-align:left; white-space:nowrap;\"><strong>\u0627\u0644\u064a\u0648\u0645 :</strong> {{ frappe.utils.get_weekday(frappe.utils.getdate(doc.posting_date)) }}</td>\r\n    </tr>\r\n    <tr>\r\n      <td style=\"padding:3px 4px; vertical-align:middle; text-align:right; white-space:nowrap;\"><strong>\u0647\u0627\u062a\u0641 :</strong> 07728619049 - 07800009060</td>\r\n      <td style=\"padding:3px 4px; vertical-align:middle; text-align:left; direction:ltr; white-space:nowrap;\"><strong>E-mail :</strong> khayliraq@hotmail.com</td>\r\n    </tr>\r\n  </table>\r\n</div>\r\n\r\n{% set is_paid = doc.status != \"Overdue\" %}\r\n\r\n{# Get USD -> IQD rate from Currency Exchange #}\r\n{% set usd_iqd_rate = 0 %}\r\n\r\n{% set ex1 = frappe.get_all(\r\n    \"Currency Exchange\",\r\n    filters={\r\n        \"from_currency\": \"USD\",\r\n        \"to_currency\": \"IQD\",\r\n        \"date\": [\"<=\", doc.posting_date]\r\n    },\r\n    fields=[\"exchange_rate\"],\r\n    order_by=\"date desc\",\r\n    limit=1\r\n) %}\r\n\r\n{% if ex1 and ex1[0].exchange_rate %}\r\n    {% set usd_iqd_rate = ex1[0].exchange_rate %}\r\n{% else %}\r\n    {% set ex2 = frappe.get_all(\r\n        \"Currency Exchange\",\r\n        filters={\r\n            \"from_currency\": \"IQD\",\r\n            \"to_currency\": \"USD\",\r\n            \"date\": [\"<=\", doc.posting_date]\r\n        },\r\n        fields=[\"exchange_rate\"],\r\n        order_by=\"date desc\",\r\n        limit=1\r\n    ) %}\r\n    {% if ex2 and ex2[0].exchange_rate %}\r\n        {% set usd_iqd_rate = 1 / ex2[0].exchange_rate %}\r\n    {% else %}\r\n        {% set usd_iqd_rate = 1 %}\r\n    {% endif %}\r\n{% endif %}\r\n\r\n{# All entered amounts are in IQD #}\r\n{% set total_iqd = doc.outstanding_amount + doc.grand_total %}\r\n{% set paid_iqd = doc.total_advance or 0 %}\r\n{% set remaining_iqd = total_iqd - paid_iqd %}\r\n\r\n{# Convert IQD to USD #}\r\n{% set paid_dollar = (paid_iqd / usd_iqd_rate) if usd_iqd_rate else 0 %}\r\n{% set remaining_dollar = (remaining_iqd / usd_iqd_rate) if usd_iqd_rate else 0 %}\r\n\r\n{% set payment_type = \"\" %}\r\n\r\n{# If due date is after posting date => credit #}\r\n{% if doc.due_date and frappe.utils.getdate(doc.due_date) > frappe.utils.getdate(doc.posting_date) %}\r\n    {% set payment_type = \"\u0622\u062c\u0644\" %}\r\n{% else %}\r\n    {# Get latest submitted Payment Entry linked to this invoice #}\r\n    {% set per_list = frappe.get_all(\r\n        \"Payment Entry Reference\",\r\n        filters={\r\n            \"reference_doctype\": doc.doctype,\r\n            \"reference_name\": doc.name\r\n        },\r\n        fields=[\"parent\"],\r\n        order_by=\"modified desc\",\r\n        limit=1\r\n    ) %}\r\n\r\n    {% if per_list and per_list[0].parent %}\r\n        {% set pe_mode = frappe.db.get_value(\r\n            \"Payment Entry\",\r\n            {\r\n                \"name\": per_list[0].parent,\r\n                \"docstatus\": 1\r\n            },\r\n            \"mode_of_payment\"\r\n        ) %}\r\n        {% set payment_type = pe_mode or \"\" %}\r\n    {% else %}\r\n        {% set payment_type = \"\" %}\r\n    {% endif %}\r\n{% endif %}\r\n\r\n<div class=\"inv-wrapper\">\r\n\r\n  <!-- Header -->\r\n  <div class=\"top-header\">\r\n    <table>\r\n      <tr>\r\n        <td style=\"width:33%; text-align:right; vertical-align:middle;\">\r\n          <div style=\"font-size:44px; font-weight:700; font-family:'Arabic Typesetting','Amiri','Noto Naskh Arabic',serif; line-height:1;\">\u062e\u064a\u0631\u0627\u062a \u0627\u0644\u0639\u0631\u0627\u0642</div>\r\n          <div style=\"font-size:14px; margin-top:6px; color:#555;\">\u0644\u0644\u0625\u0646\u062a\u0627\u062c \u0627\u0644\u0632\u0631\u0627\u0639\u064a \u0648\u0627\u0644\u062d\u064a\u0648\u0627\u0646\u064a \u0627\u0644\u0645\u062d\u062f\u0648\u062f\u0629</div>\r\n        </td>\r\n\r\n        <td style=\"width:34%; text-align:center; vertical-align:top; padding-top:0;\">\r\n          <div style=\"width:180px; height:110px; margin:0 auto; display:flex; align-items:flex-start; justify-content:center;\">\r\n            <img src=\"/private/files/cropped-cropped-LOGO1-2.png\" alt=\"Company Logo\" style=\"max-width:100%; max-height:100%; object-fit:contain;\">\r\n          </div>\r\n        </td>\r\n\r\n        <td style=\"width:33%; text-align:left; direction:ltr; vertical-align:middle;\">\r\n          <div style=\"font-size:26px; font-weight:700;\">Khayrat AL-Iraq</div>\r\n          <div style=\"font-size:14px; margin-top:6px; color:#555; white-space:nowrap;\">For agricultural &amp; livestock production</div>\r\n        </td>\r\n      </tr>\r\n    </table>\r\n  </div>\r\n  \r\n  <!-- Meta Info -->\r\n  <table style=\"width:100%; border-collapse:collapse; margin-bottom:10px;\">\r\n    <tr>\r\n    <td style=\"padding:4px 6px; white-space:nowrap; font-weight:bold; font-size:13px; width:8%; vertical-align:middle;\">\u0627\u0644\u062a\u0627\u0631\u064a\u062e :</td>\r\n    <td style=\"padding:4px 6px; font-size:13px; border-bottom:1px solid #999; text-align:center; width:14%; vertical-align:middle; white-space:nowrap;\">{{ doc.posting_date }}</td>\r\n\r\n    <td style=\"padding:4px 6px; white-space:nowrap; font-weight:bold; font-size:13px; width:8%; vertical-align:middle;\">\u0646\u0648\u0639 \u0627\u0644\u062f\u0641\u0639 :</td>\r\n    <td style=\"padding:4px 6px; font-size:13px; border-bottom:1px solid #999; text-align:center; width:14%; vertical-align:middle; white-space:nowrap;\">{{ payment_type }}</td>\r\n\r\n    <td style=\"padding:4px 6px; white-space:nowrap; font-weight:bold; font-size:13px; width:7%; vertical-align:middle;\">\u0627\u0644\u0639\u0645\u0644\u0629 :</td>\r\n    <td style=\"padding:4px 6px; font-size:13px; border-bottom:1px solid #999; text-align:center; width:9%; vertical-align:middle; white-space:nowrap;\">{{ doc.currency }}</td>\r\n\r\n    <td style=\"padding:4px 6px; white-space:nowrap; font-weight:bold; font-size:13px; width:6%; vertical-align:middle;\">\u0631\u0642\u0645 :</td>\r\n    <td style=\"padding:4px 6px; font-size:13px; border-bottom:1px solid #999; text-align:center; width:34%; vertical-align:middle; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;\">{{ doc.name }}</td>\r\n  </tr>\r\n    <tr>\r\n      <td style=\"padding:4px 6px; white-space:nowrap; font-weight:bold; font-size:13px; vertical-align:middle;\">\u0627\u0644\u0648\u0642\u062a :</td>\r\n      <td style=\"padding:4px 6px; font-size:13px; border-bottom:1px solid #999; text-align:center; vertical-align:middle;\">{{ doc.posting_time | string | truncate(8, False, '') }}</td>\r\n\r\n      <td style=\"padding:4px 6px; white-space:nowrap; font-weight:bold; font-size:13px; vertical-align:middle;\">\u062d\u0636\u0631\u0629 \u0627\u0644\u0633\u064a\u062f :</td>\r\n      <td style=\"padding:4px 6px; font-size:13px; border-bottom:1px solid #999; text-align:center; vertical-align:middle;\" colspan=\"3\">{{ doc.customer_name }}</td>\r\n\r\n      <td style=\"padding:4px 6px; white-space:nowrap; font-weight:bold; font-size:13px; vertical-align:middle;\">\u0647\u0627\u062a\u0641 \u0627\u0644\u0632\u0628\u0648\u0646 :</td>\r\n      <td style=\"padding:4px 6px; font-size:13px; border-bottom:1px solid #999; text-align:center; vertical-align:middle;\">{{ doc.contact_mobile or \"\" }}</td>\r\n    </tr>\r\n  </table>\r\n\r\n  <!-- Items Table -->\r\n  <table class=\"items-table\">\r\n    <thead>\r\n      <tr>\r\n        <th style=\"width:14%;\">\u0645\u0644\u0627\u062d\u0638\u0629</th>\r\n        <th style=\"width:14%;\">\u0627\u0644\u0639\u062f\u062f</th>\r\n        <th style=\"width:16%;\">\u0627\u0644\u0648\u0632\u0646</th>\r\n        <th style=\"width:12%;\">\u0633\u0639\u0631 \u0627\u0644\u0645\u0641\u0631\u062f</th>\r\n        <th style=\"width:16%;\">\u0627\u0644\u0645\u0628\u0644\u063a</th>\r\n        <th style=\"width:22%;\">\u0627\u0644\u062a\u0641\u0627\u0635\u064a\u0644</th>\r\n        <th style=\"width:6%;\">\u062a</th>\r\n      </tr>\r\n    </thead>\r\n    <tbody>\r\n      {% for item in doc.items %}\r\n      <tr>\r\n        <td>{{ item.remarks or \"\" }}</td>\r\n        <td>{{ \"{:,.0f}\".format(item.qty) }}</td>\r\n        <td>{{ \"{:,.2f}\".format(item.weight_per_unit * item.qty) if item.weight_per_unit else \"\" }}</td>\r\n        <td>{{ \"{:,.2f}\".format(item.rate) }}</td>\r\n        <td>{{ \"{:,.2f}\".format(item.amount) }}</td>\r\n        <td>{{ item.item_name }}</td>\r\n        <td>{{ loop.index }}</td>\r\n      </tr>\r\n      {% endfor %}\r\n    </tbody>\r\n  </table>\r\n\r\n  <!-- Summary -->\r\n  <table style=\"width:100%; border-collapse:separate; border-spacing:8px 4px; margin-top:4px;\">\r\n    <tr>\r\n      <td style=\"width:34%; vertical-align:top;\">\r\n        <table style=\"width:100%; border-collapse:collapse;\">\r\n          <tr>\r\n            <td style=\"border:1px solid #888; padding:4px 6px; font-size:13px; font-weight:bold; background:#fafafa; width:58%; white-space:nowrap;\">\u0645\u062c\u0645\u0648\u0639 \u0627\u0644\u0642\u0627\u0626\u0645\u0629</td>\r\n            <td style=\"border:1px solid #888; padding:4px 6px; font-size:13px; text-align:center; width:42%;\">{{ \"{:,.2f}\".format(doc.grand_total) }}</td>\r\n          </tr>\r\n          <tr>\r\n            <td style=\"border:1px solid #888; padding:4px 6px; font-size:13px; font-weight:bold; background:#fafafa; white-space:nowrap;\">\u0627\u0644\u0648\u0627\u0635\u0644 \u062f\u0648\u0644\u0627\u0631</td>\r\n            <td style=\"border:1px solid #888; padding:4px 6px; font-size:13px; text-align:center;\">{{ \"{:,.2f}\".format(paid_dollar) }}</td>\r\n          </tr>\r\n          <tr>\r\n            <td style=\"border:1px solid #888; padding:4px 6px; font-size:13px; font-weight:bold; background:#fafafa; white-space:nowrap;\">\u0627\u0644\u062e\u0635\u0645</td>\r\n            <td style=\"border:1px solid #888; padding:4px 6px; font-size:13px; text-align:center;\">{{ \"{:,.2f}\".format(doc.discount_amount) }}</td>\r\n          </tr>\r\n        </table>\r\n      </td>\r\n      <td style=\"width:33%; vertical-align:top;\">\r\n        <table style=\"width:100%; border-collapse:collapse;\">\r\n          <tr>\r\n            <td style=\"border:1px solid #888; padding:4px 6px; font-size:13px; font-weight:bold; background:#fafafa; width:58%; white-space:nowrap;\">\u0627\u0644\u062d\u0633\u0627\u0628 \u0627\u0644\u0633\u0627\u0628\u0642</td>\r\n            <td style=\"border:1px solid #888; padding:4px 6px; font-size:13px; text-align:center; width:42%;\">{{ \"{:,.2f}\".format(doc.outstanding_amount) }}</td>\r\n          </tr>\r\n          <tr>\r\n            <td style=\"border:1px solid #888; padding:4px 6px; font-size:13px; font-weight:bold; background:#fafafa; white-space:nowrap;\">\u0627\u0644\u0648\u0627\u0635\u0644 \u062f\u064a\u0646\u0627\u0631</td>\r\n            <td style=\"border:1px solid #888; padding:4px 6px; font-size:13px; text-align:center;\">{{ \"{:,.2f}\".format(paid_iqd) }}</td>\r\n          </tr>\r\n          <tr>\r\n            <td style=\"border:1px solid #888; padding:4px 6px; font-size:13px; font-weight:bold; background:#fafafa; white-space:nowrap;\">\u0639\u062f\u062f \u0627\u0644\u0645\u0648\u0627\u062f</td>\r\n            <td style=\"border:1px solid #888; padding:4px 6px; font-size:13px; text-align:center;\">{{ \"{:,.0f}\".format(doc.total_qty) }}</td>\r\n          </tr>\r\n        </table>\r\n      </td>\r\n      <td style=\"width:33%; vertical-align:top;\">\r\n        <table style=\"width:100%; border-collapse:collapse;\">\r\n          <tr>\r\n            <td style=\"border:1px solid #888; padding:4px 6px; font-size:13px; font-weight:bold; background:#fafafa; width:58%; white-space:nowrap;\">\u0627\u0644\u0645\u062c\u0645\u0648\u0639 \u0627\u0644\u0643\u0644\u064a</td>\r\n            <td style=\"border:1px solid #888; padding:4px 6px; font-size:13px; text-align:center; width:42%;\">{{ \"{:,.2f}\".format(doc.outstanding_amount + doc.grand_total) }}</td>\r\n          </tr>\r\n          <tr>\r\n            <td style=\"border:1px solid #888; padding:4px 6px; font-size:13px; font-weight:bold; background:#fafafa; white-space:nowrap;\">\u0627\u0644\u062d\u0633\u0627\u0628 \u0627\u0644\u0645\u062a\u0628\u0642\u064a $</td>\r\n            <td style=\"border:1px solid #888; padding:4px 6px; font-size:13px; text-align:center;\">\r\n              {% if is_paid %}0{% else %}{{ \"{:,.2f}\".format(remaining_dollar) }}{% endif %}\r\n            </td>\r\n          </tr>\r\n          <tr>\r\n            <td style=\"border:1px solid #888; padding:4px 6px; font-size:11px; font-weight:bold; background:#fafafa; white-space:nowrap;\">\u0627\u0644\u062d\u0633\u0627\u0628 \u0627\u0644\u0645\u062a\u0628\u0642\u064a \u062f\u064a\u0646\u0627\u0631</td>\r\n            <td style=\"border:1px solid #888; padding:4px 6px; font-size:13px; text-align:center;\">\r\n              {% if is_paid %}0{% else %}{{ \"{:,.2f}\".format(remaining_iqd) }}{% endif %}\r\n            </td>\r\n          </tr>\r\n        </table>\r\n      </td>\r\n    </tr>\r\n  </table>\r\n\r\n  <!-- Note -->\r\n  <table class=\"note-row\">\r\n    <tr>\r\n      <td style=\"width:100%; text-align:right;\"><strong>\u0627\u0644\u0645\u0644\u0627\u062d\u0638\u0629 :</strong> {{ doc.remarks or \"\" }}</td>\r\n    </tr>\r\n  </table>\r\n\r\n  <!-- Signatures -->\r\n  <div class=\"signatures\">\r\n    <table>\r\n      <tr>\r\n        <td>\r\n          <div class=\"sig-title\">\u0627\u0633\u0645 \u0627\u0644\u0645\u0646\u0638\u0645</div>\r\n          <div>{{ frappe.db.get_value(\"User\", doc.owner, \"full_name\") or doc.owner }}</div>\r\n        </td>\r\n        <td>\r\n          <div class=\"sig-title\">\u0627\u0644\u0645\u062c\u0647\u0632</div>\r\n        </td>\r\n      </tr>\r\n    </table>\r\n  </div>\r\n\r\n</div>",
